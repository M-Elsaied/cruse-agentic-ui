FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements.txt ./requirements-main.txt
COPY requirements-build.txt ./requirements-build.txt
COPY apps/cruse/backend/requirements.txt ./requirements-cruse.txt

# Install Python dependencies (setuptools needed for timeout-decorator build)
RUN pip install --no-cache-dir setuptools && \
    pip install --no-cache-dir \
    -r requirements-main.txt \
    -r requirements-build.txt \
    -r requirements-cruse.txt

# Copy application code
COPY . .

ENV PYTHONPATH=/app
EXPOSE 5001

CMD ["uvicorn", "apps.cruse.backend.main:app", "--host", "0.0.0.0", "--port", "5001"]
