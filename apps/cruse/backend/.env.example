# CRUSE Next-Gen Backend Environment Variables

# Clerk Authentication
CLERK_ISSUER_URL=https://your-clerk-domain.clerk.accounts.dev
CLERK_SECRET_KEY=sk_test_...

# CORS: comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting (set to 0 to disable)
MAX_DAILY_REQUESTS=50

# Database
DATABASE_URL=postgresql+asyncpg://cruse:cruse@localhost:5432/cruse

# Encryption key for BYOK API keys (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# FERNET_KEY=
